# Configuration de l'application Smile Life

# BASE_URL: L'URL de base pour les requêtes HTTP
# Utilisez cette variable pour configurer le préfixe d'URL en cas de déploiement
# avec un chemin racine personnalisé (ex: derrière un proxy ou sous-dossier)
# 
# Exemples:
#   BASE_URL=                    # URL racine (par défaut, laisser vide)
#   BASE_URL=/app                # Déploiement sous /app
#   BASE_URL=https://api.example.com  # Domaine complet
#
BASE_URL=
